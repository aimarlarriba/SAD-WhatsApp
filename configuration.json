{
  "project_name": "Whatsapp",
  "algorithm": "todos",
  "average_strategy": "macro",
  "preprocessing": {
    "test_split": 0,
    "target_variable": "sentiment",
    "drop_features": ["reviewID", "gender", "location", "date", "source"],
    "missing_values": "none",
    "impute_strategy": "median",
    "scaling": "standard",
    "sampling": "smote",
    "min_samples": 4,
    "text_processing": {
      "enabled": true,
      "columns": ["content"],
      "method": "tf-idf",
      "language": "english"
}
  },
  "hyperparameters": {
    "knn": {
      "k_min": 3,
      "k_max": 9,
      "p_min": 1,
      "p_max": 2,
      "weights": ["uniform", "distance"]
    },
    "trees": {
      "max_depth": [5, 10, 15],
      "min_samples_leaf": [2, 5]
    },
    "random_forest": {
        "n_estimators": [50, 100, 200],
        "max_depth": [5, 10, 20]
    },
    "naive_bayes": {
      "n_bins": [5, 10],
      "alphas": [0.5, 1.0],
      "min_categories": null
    }
  }
}
